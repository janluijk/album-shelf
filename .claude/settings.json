{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run test:*)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(npm run db:generate)",
      "Bash(npx vitest run:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx backlog.md:*)",
      "Bash(backlog:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/web-setup.sh"
          }
        ]
      }
    ]
  }
}
